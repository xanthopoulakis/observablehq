kinoEmbeds = await import("https://cdn.jsdelivr.net/gh/xanthopoulakis/observablehq@main/kino/embeds.js")

viewof lang = Inputs.radio(
  new Map([
    ["Ελληνικά", "el"],
    ["English", "en"]
  ]),
  {label: "Γλώσσα / Language", value: "el"}
)

catalog = await kinoEmbeds.get_embed_catalog(lang)

embed = (id) => catalog.find((d) => d.id === id)

md`# KINO embeds

This notebook is the modular companion to the long-form KINO essay.

Each section below is designed to stand on its own:
- as an iframe inside a media article
- as a standalone Observable share URL
- as the visual backbone of a post on X, LinkedIn, or elsewhere

The copy is localized through the shared repository bundle, so the same notebook can switch between Greek and English without rewriting headings by hand.`

md`## ${embed("fairness").title}

${embed("fairness").hook}`

fairness = await kinoEmbeds.create_fairness_section({Inputs, html, md, lang})

md`## ${embed("surrogate_fit").title}

${embed("surrogate_fit").hook}`

surrogateFit = await kinoEmbeds.create_surrogate_fit_plot({Inputs, html, md, lang, width: 960})

