md`## ${embed("parity_window").title}

${embed("parity_window").hook}`

parityWindow = await kinoEmbeds.create_parity_window_plot({
  Inputs,
  html,
  md,
  lang,
  width: 960,
  parity_target: "draw",
  parity_window: 100
})

